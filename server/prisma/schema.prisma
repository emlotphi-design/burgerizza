generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Users are managed by raw pg (see db.js / authController.js).
// userId here is the UUID string from the pg users table.

model Burger {
  id         String   @id @default(cuid())
  name       String
  bun        String
  sauces     Json     @default("[]")
  meats      Json     @default("{}")
  cheeses    Json     @default("{}")
  vegetables Json     @default("[]")
  totalPrice Float    @default(0)
  image      String?
  userId     String
  createdAt  DateTime @default(now())
}

model Pizza {
  id         String   @id @default(cuid())
  name       String
  dough      String
  sauce      String
  cheese     String
  meats      Json     @default("[]")
  vegetables Json     @default("[]")
  totalPrice Float    @default(0)
  image      String?
  userId     String
  createdAt  DateTime @default(now())
}

model Order {
  id         String   @id @default(cuid())
  userId     String
  items      Json
  totalPrice Float
  status     String   @default("pending")
  createdAt  DateTime @default(now())
}
