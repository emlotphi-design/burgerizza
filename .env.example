# ── Supabase (frontend) ──────────────────────────────────
# Found in: Supabase Dashboard → Project Settings → API
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6...

# ── Backend API URL (frontend) ───────────────────────────
# Local dev: http://localhost:3001
# Production: your Railway backend URL
VITE_API_URL=http://localhost:3001

# ── PostgreSQL — Railway provides this automatically ─────
DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DATABASE

# ── Supabase (backend — service role, keep secret!) ──────
# Found in: Supabase Dashboard → Project Settings → API → service_role
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6...

# ── Server port (Railway sets this automatically) ────────
PORT=3001

# ── CORS: your Vercel frontend URL ───────────────────────
FRONTEND_URL=https://your-app.vercel.app
